{
  "manifest_version": 3,
  "name": "UOSZEUSX ⋄ mobile",
  "version": "2.0",
  "description": "Mobile mode for ZeusX at Osnabrück University.",
  "browser_specific_settings": {
    "gecko": {
      "id": "uos-zeusx-mobile@lkiesow.io",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "121.0"
    }
  },
  "icons": {
    "48": "icons/zeus-mobile.png",
    "128": "icons/zeus-mobile-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://zeusx.uni-osnabrueck.de/*"
      ],
      "js": [
        "zeusx-mobile.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://cas.uni-osnabrueck.de/*"
      ],
      "js": [
        "cas-mobile.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
